<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="10dp"
    app:strokeWidth="0dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:gravity="center">

        <FrameLayout
            android:id="@+id/badgeIconBg"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_badge_icon"
            android:layout_marginBottom="10dp">
            <ImageView
                android:id="@+id/ivBadgeIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_badge_default" />
        </FrameLayout>

        <TextView android:id="@+id/tvBadgeName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="12sp" android:textColor="@color/ink" android:fontFamily="sans-serif-medium" android:gravity="center" android:layout_marginBottom="3dp"/>
        <TextView android:id="@+id/tvBadgeDesc" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="10sp" android:textColor="@color/ink_3" android:gravity="center" android:lineSpacingMultiplier="1.4" android:layout_marginBottom="8dp"/>
        <TextView android:id="@+id/tvBadgeStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="9sp" android:fontFamily="sans-serif-medium" android:paddingStart="8dp" android:paddingEnd="8dp" android:paddingTop="2dp" android:paddingBottom="2dp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
