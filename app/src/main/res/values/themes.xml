<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SpendSmart" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ink</item>
        <item name="colorPrimaryVariant">@color/ink_2</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/ink_3</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/off_white</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:textColor">@color/ink</item>
        <item name="materialCardViewStyle">@style/CardStyle</item>
    </style>

    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="TabStyle" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabTextColor">@color/ink_3</item>
        <item name="tabSelectedTextColor">@color/ink</item>
        <item name="tabIndicatorColor">@color/ink</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="tabBackground">@android:color/transparent</item>
        <item name="tabTextAppearance">@style/TabTextAppearance</item>
    </style>

    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="SectionTitle">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/ink_4</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="StatValue">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:fontFamily">serif</item>
    </style>

    <style name="StatLabel">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/ink_4</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="BtnSolid" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/ink</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">13sp</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="BtnOutline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/ink_2</item>
        <item name="strokeColor">@color/border</item>
        <item name="android:textSize">13sp</item>
        <item name="cornerRadius">6dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <style name="InputStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusBottomEnd">6dp</item>
        <item name="boxCornerRadiusBottomStart">6dp</item>
        <item name="boxCornerRadiusTopEnd">6dp</item>
        <item name="boxCornerRadiusTopStart">6dp</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="hintTextColor">@color/ink_3</item>
        <item name="android:textColorHint">@color/ink_4</item>
        <item name="boxBackgroundColor">@color/white</item>
    </style>
</resources>
