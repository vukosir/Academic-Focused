@model List<CMCS.Models.MonthlyClaim>
@{
    ViewData["Title"] = "Claim Status Tracking";
    var stats = ViewBag.Statistics as dynamic;
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Claim Status Tracking</h2>
        <div>
            <a asp-action="Manage" class="btn btn-outline-primary me-2">
                <i class="bi bi-gear"></i> Manage Claims
            </a>
            <a asp-action="Review" class="btn btn-outline-success">
                <i class="bi bi-eye"></i> Review Pending
            </a>
        </div>
    </div>

    <!-- Real-time Statistics -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h3 class="text-primary">@stats.TotalClaims</h3>
                    <p class="card-text">Total Claims</p>
                    <small class="text-muted">R@(stats.TotalAmount.ToString("N2"))</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h3 class="text-success">@stats.ApprovedClaims</h3>
                    <p class="card-text">Approved</p>
                    <small class="text-muted">R@(stats.ApprovedAmount.ToString("N2"))</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <h3 class="text-warning">@stats.PendingClaims</h3>
                    <p class="card-text">Pending</p>
                    <small class="text-muted">R@(stats.PendingAmount.ToString("N2"))</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <h3 class="text-danger">@stats.RejectedClaims</h3>
                    <p class="card-text">Rejected</p>
                    <small class="text-muted">R@(stats.RejectedAmount.ToString("N2"))</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Progress Visualization -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Approval Progress</h5>
                </div>
                <div class="card-body">
                    <div class="progress" style="height: 30px;">
                        @if (stats.TotalClaims > 0)
                        {
                            var approvedPercent = (stats.ApprovedClaims * 100) / stats.TotalClaims;
                            var pendingPercent = (stats.PendingClaims * 100) / stats.TotalClaims;
                            var rejectedPercent = (stats.RejectedClaims * 100) / stats.TotalClaims;

                            <div class="progress-bar bg-success" role="progressbar"
                                 style="width: @(approvedPercent)%"
                                 aria-valuenow="@(approvedPercent)" aria-valuemin="0" aria-valuemax="100">
                                Approved: @(stats.ApprovedClaims) (@(approvedPercent.ToString("F1"))%)
                            </div>
                            <div class="progress-bar bg-warning" role="progressbar"
                                 style="width: @(pendingPercent)%"
                                 aria-valuenow="@(pendingPercent)" aria-valuemin="0" aria-valuemax="100">
                                Pending: @(stats.PendingClaims) (@(pendingPercent.ToString("F1"))%)
                            </div>
                            <div class="progress-bar bg-danger" role="progressbar"
                                 style="width: @(rejectedPercent)%"
                                 aria-valuenow="@(rejectedPercent)" aria-valuemin="0" aria-valuemax="100">
                                Rejected: @(stats.RejectedClaims) (@(rejectedPercent.ToString("F1"))%)
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Status Timeline -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">Recent Claims Activity</h5>
                </div>
                <div class="card-body">
                    @if (!Model.Any())
                    {
                        <div class="alert alert-info text-center">
                            <h5>No claims activity</h5>
                            <p class="mb-0">There are no claims to display.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Claim ID</th>
                                        <th>Lecturer</th>
                                        <th>Department</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                        <th>Progress</th>
                                        <th>Submission Date</th>
                                        <th>Last Updated</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var claim in Model)
                                    {
                                        <tr>
                                            <td>@claim.Id</td>
                                            <td>
                                                <div>@claim.FullName</div>
                                                <small class="text-muted">@claim.LecturerId</small>
                                            </td>
                                            <td>@claim.Department</td>
                                            <td><strong>R@(claim.TotalAmount.ToString("F2"))</strong></td>
                                            <td>
                                                <span class="badge bg-@claim.StatusColor">
                                                    @claim.Status
                                                </span>
                                            </td>
                                            <td>
                                                <div class="progress" style="height: 8px;">
                                                    @if (claim.Status == "Approved")
                                                    {
                                                        <div class="progress-bar bg-success" style="width: 100%"></div>
                                                    }
                                                    else if (claim.Status == "Rejected")
                                                    {
                                                        <div class="progress-bar bg-danger" style="width: 100%"></div>
                                                    }
                                                    else
                                                    {
                                                        <div class="progress-bar bg-warning" style="width: 50%"></div>
                                                    }
                                                </div>
                                                <small class="text-muted">
                                                    @if (claim.Status == "Pending")
                                                    {
                                                        <text>Under Review</text>
                                                    }
                                                    else if (claim.Status == "Approved")
                                                    {
                                                        <text>Completed</text>
                                                    }
                                                    else
                                                    {
                                                        <text>Rejected</text>
                                                    }
                                                </small>
                                            </td>
                                            <td>@claim.SubmissionDate.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                @if (claim.ApprovalDate.HasValue)
                                                {
                                                    @claim.ApprovalDate.Value.ToString("MMM dd, yyyy HH:mm")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Not reviewed</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <button type="button" class="btn btn-info"
                                                            data-bs-toggle="modal"
                                                            data-bs-target="#trackingModal@(claim.Id)">
                                                        <i class="bi bi-clock-history"></i> Track
                                                    </button>
                                                    @if (!string.IsNullOrEmpty(claim.FileName))
                                                    {
                                                        <a asp-action="DownloadDocument" asp-route-id="@claim.Id"
                                                           class="btn btn-outline-primary">
                                                            <i class="bi bi-download"></i> Document
                                                        </a>
                                                    }
                                                </div>

                                                <!-- Tracking Details Modal -->
                                                <div class="modal fade" id="trackingModal@(claim.Id)" tabindex="-1" aria-labelledby="trackingModalLabel@(claim.Id)" aria-hidden="true">
                                                    <div class="modal-dialog">
                                                        <div class="modal-content">
                                                            <div class="modal-header">
                                                                <h5 class="modal-title" id="trackingModalLabel@(claim.Id)">Tracking Details - Claim @claim.Id</h5>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                            </div>
                                                            <div class="modal-body">
                                                                <div class="timeline">
                                                                    <div class="timeline-item @(claim.Status != "Pending" ? "completed" : "active")">
                                                                        <div class="timeline-marker bg-primary"></div>
                                                                        <div class="timeline-content">
                                                                            <h6>Claim Submitted</h6>
                                                                            <p class="text-muted mb-0">@claim.SubmissionDate.ToString("MMM dd, yyyy HH:mm")</p>
                                                                            <small>By: @claim.FullName</small>
                                                                        </div>
                                                                    </div>

                                                                    @if (claim.Status != "Pending")
                                                                    {
                                                                        <div class="timeline-item completed">
                                                                            <div class="timeline-marker bg-@claim.StatusColor"></div>
                                                                            <div class="timeline-content">
                                                                                <h6>Claim @claim.Status</h6>
                                                                                <p class="text-muted mb-0">@claim.ApprovalDate?.ToString("MMM dd, yyyy HH:mm")</p>
                                                                                <small>By: @claim.ApprovedBy</small>
                                                                                @if (claim.Status == "Rejected" && !string.IsNullOrEmpty(claim.RejectionReason))
                                                                                {
                                                                                    <div class="alert alert-danger mt-2">
                                                                                        <strong>Reason:</strong> @claim.RejectionReason
                                                                                    </div>
                                                                                }
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                    else
                                                                    {
                                                                        <div class="timeline-item pending">
                                                                            <div class="timeline-marker bg-warning"></div>
                                                                            <div class="timeline-content">
                                                                                <h6>Under Review</h6>
                                                                                <p class="text-muted mb-0">Awaiting coordinator approval</p>
                                                                                <small>Current status: Pending</small>
                                                                            </div>
                                                                        </div>
                                                                    }
                                                                </div>
                                                            </div>
                                                            <div class="modal-footer">
                                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .timeline {
        position: relative;
        padding-left: 30px;
    }

    .timeline-item {
        position: relative;
        margin-bottom: 20px;
    }

    .timeline-marker {
        position: absolute;
        left: -30px;
        top: 0;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        text-align: center;
        line-height: 20px;
        color: white;
    }

    .timeline-content {
        padding: 10px;
        border-radius: 5px;
        background: #f8f9fa;
    }

    .timeline-item.completed .timeline-content {
        background: #e8f5e8;
    }

    .timeline-item.active .timeline-content {
        background: #fff3cd;
    }

    .timeline-item.pending .timeline-content {
        background: #e2e3e5;
    }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var modalElements = document.querySelectorAll('.modal');
            modalElements.forEach(function(modalElement) {
                var modal = new bootstrap.Modal(modalElement);

                var closeButtons = modalElement.querySelectorAll('[data-bs-dismiss="modal"]');
                closeButtons.forEach(function(closeButton) {
                    closeButton.addEventListener('click', function() {
                        modal.hide();
                    });
                });
            });

            var allCloseButtons = document.querySelectorAll('[data-bs-dismiss="modal"]');
            allCloseButtons.forEach(function(button) {
                button.addEventListener('click', function() {
                    var modal = bootstrap.Modal.getInstance(this.closest('.modal'));
                    if (modal) {
                        modal.hide();
                    }
                });
            });
        });
    </script>
}
