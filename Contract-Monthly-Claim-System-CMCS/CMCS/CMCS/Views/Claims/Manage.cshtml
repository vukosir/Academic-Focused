@model List<CMCS.Models.MonthlyClaim>
@{
    ViewData["Title"] = "Manage Claims";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active">Manage Claims</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>
            <i class="bi bi-gear"></i> Claims Management
        </h2>
        <div>
            <a asp-action="Track" class="btn btn-outline-info me-2">
                <i class="bi bi-graph-up"></i> View Status Tracking
            </a>
            <a asp-action="Review" class="btn btn-outline-primary">
                <i class="bi bi-eye"></i> Review Pending Claims
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@Model.Count</h4>
                            <p class="card-text">Total Claims</p>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-files" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@Model.Count(c => c.Status == "Approved")</h4>
                            <p class="card-text">Approved</p>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-check-circle" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@Model.Count(c => c.Status == "Pending")</h4>
                            <p class="card-text">Pending</p>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-clock" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-danger">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@Model.Count(c => c.Status == "Rejected")</h4>
                            <p class="card-text">Rejected</p>
                        </div>
                        <div class="align-self-center">
                            <i class="bi bi-x-circle" style="font-size: 2rem;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Claims Table -->
    <div class="card shadow-sm">
        <div class="card-header">
            <h5 class="card-title mb-0">
                <i class="bi bi-list-ul"></i> All Claims
            </h5>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="alert alert-info text-center">
                    <h5>
                        <i class="bi bi-inbox"></i> No Claims Found
                    </h5>
                    <p class="mb-0">There are no claims in the system yet.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover" id="claimsTable">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Lecturer ID</th>
                                <th>Name</th>
                                <th>Department</th>
                                <th>Hours</th>
                                <th>Rate</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Submission Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var claim in Model)
                            {
                                <tr>
                                    <td>@claim.Id</td>
                                    <td>@claim.LecturerId</td>
                                    <td>@claim.FullName</td>
                                    <td>@claim.Department</td>
                                    <td>@claim.HoursWorked</td>
                                    <td>R@(claim.HourlyRate.ToString("F2"))</td>
                                    <td><strong>R@(claim.TotalAmount.ToString("F2"))</strong></td>
                                    <td>
                                        <span class="badge bg-@claim.StatusColor">
                                            @claim.Status
                                        </span>
                                    </td>
                                    <td>@claim.SubmissionDate.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <button type="button" class="btn btn-info"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#detailsModal@claim.Id">
                                                <i class="bi bi-eye"></i> Details
                                            </button>
                                            @if (claim.Status == "Pending")
                                            {
                                                <form asp-action="Approve" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@claim.Id" />
                                                    <button type="submit" class="btn btn-success"
                                                            onclick="return confirm('Approve claim from @claim.FullName?')">
                                                        <i class="bi bi-check"></i> Approve
                                                    </button>
                                                </form>
                                                <button type="button" class="btn btn-danger"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#rejectModal@claim.Id">
                                                    <i class="bi bi-x"></i> Reject
                                                </button>
                                            }
                                            <form asp-action="Delete" method="post" class="d-inline"
                                                  onsubmit="return confirm('Are you sure you want to delete claim @claim.Id from @claim.FullName? This action cannot be undone.');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@claim.Id" />
                                                <button type="submit" class="btn btn-outline-danger">
                                                    <i class="bi bi-trash"></i> Delete
                                                </button>
                                            </form>
                                        </div>

                                        <!-- Details Modal -->
                                        <div class="modal fade" id="detailsModal@claim.Id" tabindex="-1">
                                            <div class="modal-dialog modal-lg">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Claim Details - @claim.LecturerId</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <partial name="_ClaimDetails" model="claim" />
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Reject Modal -->
                                        <div class="modal fade" id="rejectModal@claim.Id" tabindex="-1">
                                            <div class="modal-dialog">
                                                <div class="modal-content">
                                                    <form asp-action="Reject" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@claim.Id" />
                                                        <div class="modal-header">
                                                            <h5 class="modal-title">Reject Claim</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        <div class="modal-body">
                                                            <p>Reject claim from <strong>@claim.FullName</strong>?</p>
                                                            <div class="mb-3">
                                                                <label class="form-label">Rejection Reason</label>
                                                                <textarea name="rejectionReason" class="form-control" rows="3"
                                                                  placeholder="Please provide a reason for rejection..." required></textarea>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                            <button type="submit" class="btn btn-danger">Confirm Reject</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#claimsTable').DataTable({
                "pageLength": 10,
                "order": [[8, 'desc']],
                "language": {
                    "search": "Search claims:",
                    "lengthMenu": "Show _MENU_ claims per page",
                    "info": "Showing _START_ to _END_ of _TOTAL_ claims"
                }
            });
        });
    </script>
}
