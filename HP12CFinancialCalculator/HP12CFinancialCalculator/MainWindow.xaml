<Window x:Class="HP12CFinancialCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HP 12C Financial Calculator" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <!-- TextBlock Style -->
        <Style x:Key="DisplayTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Courier New"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="DisplayTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Courier New"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>

        <Style x:Key="CalculatorButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="5,2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#D0D0D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FunctionButtonStyle" TargetType="Button" BasedOn="{StaticResource CalculatorButtonStyle}">
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="FinancialButtonStyle" TargetType="Button" BasedOn="{StaticResource CalculatorButtonStyle}">
            <Setter Property="Background" Value="#D0E8FF"/>
            <Setter Property="Foreground" Value="#0066CC"/>
        </Style>

        <Style x:Key="OrangeButtonStyle" TargetType="Button" BasedOn="{StaticResource CalculatorButtonStyle}">
            <Setter Property="Background" Value="#FF9500"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style x:Key="BlueButtonStyle" TargetType="Button" BasedOn="{StaticResource CalculatorButtonStyle}">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid Background="#2C2C2C">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E1E1E" Padding="10">
            <TextBlock Text="HP 12C Financial Calculator" Foreground="White" 
                      FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Background="#3C3C3C" BorderThickness="0">
            <!-- Basic Calculator Tab -->
            <TabItem Header="Basic" Background="#4C4C4C" Foreground="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Display -->
                    <Border Grid.Row="0" Background="#C0C0C0" BorderBrush="#808080" BorderThickness="1" Margin="10" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Register Indicators -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock x:Name="RPNIndicator" Text="RPN" Foreground="Blue" Margin="0,0,10,0"/>
                                <TextBlock x:Name="CIndicator" Text="C" Foreground="Red" Margin="0,0,10,0" Visibility="Collapsed"/>
                                <TextBlock x:Name="BeginEndIndicator" Text="BEGIN" Foreground="Green" Visibility="Collapsed"/>
                            </StackPanel>

                            <!-- Stack Display -->
                            <ItemsControl Grid.Row="1" x:Name="StackDisplay" Margin="0,5">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Style="{StaticResource DisplayTextBlockStyle}" 
                                                  Foreground="#666666" FontSize="14"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Main Display -->
                            <TextBox Grid.Row="2" x:Name="MainDisplay" Text="0" 
                                    Style="{StaticResource DisplayTextBoxStyle}" FontSize="24" FontWeight="Bold"/>
                        </Grid>
                    </Border>

                    <!-- Basic Calculator Buttons -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Row 1 -->
                            <Button x:Name="BtnN" Grid.Row="0" Grid.Column="0" Content="n" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click"/>
                            <Button x:Name="BtnI" Grid.Row="0" Grid.Column="1" Content="i" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click"/>
                            <Button x:Name="BtnPV" Grid.Row="0" Grid.Column="2" Content="PV" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click"/>
                            <Button x:Name="BtnPMT" Grid.Row="0" Grid.Column="3" Content="PMT" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click"/>
                            <Button x:Name="BtnFV" Grid.Row="0" Grid.Column="4" Content="FV" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click"/>

                            <!-- Row 2 -->
                            <Button x:Name="Btn7" Grid.Row="1" Grid.Column="0" Content="7" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
                            <Button x:Name="Btn8" Grid.Row="1" Grid.Column="1" Content="8" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
                            <Button x:Name="Btn9" Grid.Row="1" Grid.Column="2" Content="9" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
                            <Button x:Name="BtnDivide" Grid.Row="1" Grid.Column="3" Content="÷" Style="{StaticResource CalculatorButtonStyle}" Click="Operation_Click"/>
                            <Button x:Name="BtnCHS" Grid.Row="1" Grid.Column="4" Content="CHS" Style="{StaticResource FunctionButtonStyle}" Click="FunctionButton_Click"/>

                            <!-- Row 3 -->
                            <Button x:Name="Btn4" Grid.Row="2" Grid.Column="0" Content="4" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
                            <Button x:Name="Btn5" Grid.Row="2" Grid.Column="1" Content="5" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
                            <Button x:Name="Btn6" Grid.Row="2" Grid.Column="2" Content="6" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
                            <Button x:Name="BtnMultiply" Grid.Row="2" Grid.Column="3" Content="×" Style="{StaticResource CalculatorButtonStyle}" Click="Operation_Click"/>
                            <Button x:Name="BtnEEX" Grid.Row="2" Grid.Column="4" Content="EEX" Style="{StaticResource FunctionButtonStyle}" Click="FunctionButton_Click"/>

                            <!-- Row 4 -->
                            <Button x:Name="Btn1" Grid.Row="3" Grid.Column="0" Content="1" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
                            <Button x:Name="Btn2" Grid.Row="3" Grid.Column="1" Content="2" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
                            <Button x:Name="Btn3" Grid.Row="3" Grid.Column="2" Content="3" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
                            <Button x:Name="BtnSubtract" Grid.Row="3" Grid.Column="3" Content="-" Style="{StaticResource CalculatorButtonStyle}" Click="Operation_Click"/>
                            <Button x:Name="BtnRCL" Grid.Row="3" Grid.Column="4" Content="RCL" Style="{StaticResource FunctionButtonStyle}" Click="FunctionButton_Click"/>

                            <!-- Row 5 -->
                            <Button x:Name="Btn0" Grid.Row="4" Grid.Column="0" Content="0" Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
                            <Button x:Name="BtnDecimal" Grid.Row="4" Grid.Column="1" Content="." Style="{StaticResource CalculatorButtonStyle}" Click="Number_Click"/>
                            <Button x:Name="BtnEnter" Grid.Row="4" Grid.Column="2" Content="ENTER" Style="{StaticResource OrangeButtonStyle}" Click="Enter_Click"/>
                            <Button x:Name="BtnAdd" Grid.Row="4" Grid.Column="3" Content="+" Style="{StaticResource CalculatorButtonStyle}" Click="Operation_Click"/>
                            <Button x:Name="BtnSTO" Grid.Row="4" Grid.Column="4" Content="STO" Style="{StaticResource FunctionButtonStyle}" Click="FunctionButton_Click"/>

                            <!-- Row 6 - Function Buttons -->
                            <Button x:Name="BtnClear" Grid.Row="5" Grid.Column="0" Content="CLx" Style="{StaticResource FunctionButtonStyle}" Click="FunctionButton_Click"/>
                            <Button x:Name="BtnXExchangeY" Grid.Row="5" Grid.Column="1" Content="X↔Y" Style="{StaticResource FunctionButtonStyle}" Click="FunctionButton_Click"/>
                            <Button x:Name="BtnRolldown" Grid.Row="5" Grid.Column="2" Content="R↓" Style="{StaticResource FunctionButtonStyle}" Click="FunctionButton_Click"/>
                            <Button x:Name="BtnXY" Grid.Row="5" Grid.Column="3" Content="x√y" Style="{StaticResource FunctionButtonStyle}" Click="FunctionButton_Click"/>
                            <Button x:Name="BtnPercent" Grid.Row="5" Grid.Column="4" Content="%" Style="{StaticResource FunctionButtonStyle}" Click="FunctionButton_Click"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Financial Functions Tab -->
            <TabItem Header="Financial" Background="#4C4C4C" Foreground="White">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Time Value of Money -->
                        <GroupBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Header="Time Value of Money" Margin="5">
                            <StackPanel>
                                <Button x:Name="BtnN_Financial" Content="N - Number of Periods" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnI_Financial" Content="I - Interest Rate" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnPV_Financial" Content="PV - Present Value" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnPMT_Financial" Content="PMT - Payment" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnFV_Financial" Content="FV - Future Value" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnBeginEnd" Content="BEG/END" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Cash Flow Analysis -->
                        <GroupBox Grid.Row="1" Grid.Column="0" Header="Cash Flow Analysis" Margin="5">
                            <StackPanel>
                                <Button x:Name="BtnCF0" Content="CF₀ - Initial Flow" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnCFj" Content="CFj - Cash Flow" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnNj" Content="Nj - Repeat" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnNPV" Content="NPV" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnIRR" Content="IRR" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Bond Calculations -->
                        <GroupBox Grid.Row="1" Grid.Column="1" Header="Bond Calculations" Margin="5">
                            <StackPanel>
                                <Button x:Name="BtnYTM" Content="YTM" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnPrice" Content="PRICE" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnDuration" Content="DURATION" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnAccrued" Content="ACCRUED" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Depreciation -->
                        <GroupBox Grid.Row="1" Grid.Column="2" Header="Depreciation" Margin="5">
                            <StackPanel>
                                <Button x:Name="BtnSL" Content="SL" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnSOYD" Content="SOYD" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnDB" Content="DB" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Statistics -->
                        <GroupBox Grid.Row="2" Grid.Column="0" Header="Statistics" Margin="5">
                            <StackPanel>
                                <Button x:Name="BtnMean" Content="MEAN" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnStdDev" Content="s - Std Dev" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnLinReg" Content="LIN REG" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnSum" Content="Σ" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Date Calculations -->
                        <GroupBox Grid.Row="2" Grid.Column="1" Header="Date Calculations" Margin="5">
                            <StackPanel>
                                <Button x:Name="BtnDate" Content="DATE" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnDays" Content="DAYS" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnDOW" Content="DOW" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Conversions -->
                        <GroupBox Grid.Row="2" Grid.Column="2" Header="Conversions" Margin="5">
                            <StackPanel>
                                <Button x:Name="BtnNominal" Content="NOMINAL" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnEffective" Content="EFFECTIVE" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnPercentChange" Content="%CHG" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                                <Button x:Name="BtnPercentTotal" Content="%T" Style="{StaticResource FinancialButtonStyle}" Click="FinancialButton_Click" Margin="2"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Programming -->
                        <GroupBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Header="Programming &amp; Memory" Margin="5">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnGTO" Content="GTO" Style="{StaticResource BlueButtonStyle}" Click="FunctionButton_Click" Margin="2"/>
                                <Button x:Name="BtnGSB" Content="GSB" Style="{StaticResource BlueButtonStyle}" Click="FunctionButton_Click" Margin="2"/>
                                <Button x:Name="BtnRPN" Content="RPN" Style="{StaticResource BlueButtonStyle}" Click="FunctionButton_Click" Margin="2"/>
                                <Button x:Name="BtnSST" Content="SST" Style="{StaticResource BlueButtonStyle}" Click="FunctionButton_Click" Margin="2"/>
                                <Button x:Name="BtnBST" Content="BST" Style="{StaticResource BlueButtonStyle}" Click="FunctionButton_Click" Margin="2"/>
                                <Button x:Name="BtnFix" Content="FIX" Style="{StaticResource BlueButtonStyle}" Click="FunctionButton_Click" Margin="2"/>
                                <Button x:Name="BtnSci" Content="SCI" Style="{StaticResource BlueButtonStyle}" Click="FunctionButton_Click" Margin="2"/>
                                <Button x:Name="BtnEng" Content="ENG" Style="{StaticResource BlueButtonStyle}" Click="FunctionButton_Click" Margin="2"/>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- Memory &amp; Registers Tab -->
            <TabItem Header="Memory" Background="#4C4C4C" Foreground="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Memory Controls -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
                        <Button x:Name="BtnClearMem" Content="Clear Memory" Style="{StaticResource BlueButtonStyle}" Click="ClearMemory_Click" Margin="5"/>
                        <Button x:Name="BtnViewAll" Content="View All Registers" Style="{StaticResource BlueButtonStyle}" Click="ViewAllRegisters_Click" Margin="5"/>
                    </StackPanel>

                    <!-- Memory Display -->
                    <DataGrid Grid.Row="1" x:Name="MemoryGrid" Margin="10" AutoGenerateColumns="False"
                             Background="#E8E8E8" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Register" Binding="{Binding Key}" Width="*"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="#1E1E1E">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Foreground="White" Text="Ready"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="ModeText" Foreground="LightGreen" Text="RPN Mode"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>